---
config:
  layout: elk
---
flowchart TD

    subgraph FUENTES["Fuentes de Datos Principales"]
        direction LR

        subgraph SNIB["SNIB<br/>(Sistema Nacional de Información<br/>sobre Biodiversidad de México)"]
            S1["45M+ registros de presencia<br/>114K+ especies"]
            S2["Fichas técnicas de especies<br/>nativas y exóticas"]
            S3["Mapas, imágenes satelitales<br/>y fotografías de ecosistemas"]
        end

        subgraph GBIF["GBIF<br/>(Sistema Global de Información<br/>sobre Biodiversidad)"]
            G1["Red internacional de nodos<br/>coordinada desde Copenhague"]
            G2["Estándar Darwin Core<br/>para registros de especies"]
            G3["Datos abiertos bajo<br/>licencias Creative Commons"]
        end

        subgraph WORLDCLIM["WorldClim<br/>(Base de Datos Meteorológicos<br/>y Climáticos Globales)"]
            W1["Temperatura mín/media/máx<br/>Precipitación, radiación, viento"]
            W2["19 variables bioclimáticas"]
            W3["Resoluciones: 30s (~1km²)<br/>hasta 10min (~340km²)"]
        end
    end

    subgraph API_FUENTE["Endpoints por Fuente de Datos"]
        direction TB

        EP1["GET /info<br/>→ name, description,<br/>source_url, download_url, dict_url"]

        EP2["GET /variables<br/>→ id, name, level_size,<br/>filter_fields, available_grids, metadata"]

        EP3["GET /variables/:id<br/>→ niveles de la variable<br/>(params: q, offset, limit)"]

        EP4["GET /get-data/:id<br/>→ cells por nivel y malla<br/>(params: grid_id, levels_id,<br/>filter_names, filter_values)"]
    end

    subgraph SCHEMAS["Esquemas de Datos"]
        direction TB

        SC1["Filter<br/>• name: string<br/>• value: string"]

        SC2["Variable State<br/>• variableId<br/>• datasetId<br/>• levelId<br/>• filters → array[Filter]"]

        SC3["Ensamble<br/>• target → array[VariableState]<br/>• covariables → array[VariableState]<br/>• grid-id: string<br/>• precision: float"]
    end

    subgraph SERVICIO["Servicio de Procesamiento de Ensambles"]
        direction TB

        SV1["GET /region-grids<br/>→ id, region, grid<br/>(param: q)"]

        SV2["GET /region-grids/:id<br/>→ GeoJSON de la malla"]

        SV3["GET /datasets<br/>→ id, name<br/>(listado de fuentes disponibles)"]

        SV4["GET /datasets/:id<br/>→ URL base para endpoints<br/>de la fuente de datos"]

        SV5["Cálculo de<br/>score y épsilon<br/>por ensamble"]
    end

    FUENTES -->|"Expone datos vía"| API_FUENTE
    API_FUENTE -->|"Datos de variables<br/>por malla y nivel"| SERVICIO
    SC3 -->|"Define el ensamble<br/>a procesar"| SERVICIO
    SC2 -->|"Estado de variables<br/>(target y covariables)"| SC3
    SC1 -->|"Filtros aplicados<br/>a cada variable"| SC2
    SV4 -->|"Conecta con"| API_FUENTE
    SERVICIO --> OUT["Ensamble procesado<br/>con scores y épsilons<br/>por malla y región"]

